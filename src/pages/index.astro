---
import { getCollection } from 'astro:content';
import BlogPostCard from '../components/BlogPostCard.astro';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
	title="Blogy | Personal technical blog"
	description="A personal blog for Markdown-based technical articles."
>
	<main class="page-shell">
		<section class="grid gap-4 py-[clamp(2rem,8vw,5rem)] pb-[clamp(1.8rem,5vw,3.4rem)]" aria-labelledby="page-title">
			<p class="eyebrow">Personal technical notes</p>
			<h1 id="page-title" class="hero-title">Blogy</h1>
			<p class="hero-copy">
				Long-form articles written in Markdown, focused on backend systems,
				databases, architecture, and the tradeoffs behind production software.
			</p>
		</section>

		<section id="articles" aria-label="Articles">
			{posts.map((post) => (
				<BlogPostCard
					href={`/blog/${post.id}/`}
					title={post.data.title}
					description={post.data.description}
					pubDate={post.data.pubDate}
					tags={post.data.tags}
				/>
			))}
		</section>
	</main>
</Layout>
