---
import { getCollection } from 'astro:content';
import BlogPostCard from '../components/BlogPostCard.astro';
import Layout from '../layouts/Layout.astro';
import { getHomepageItems, getSeriesHref } from '../lib/series';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const homepageItems = getHomepageItems(posts);
---

<Layout
	title="Petar I | Personal technical blog"
	description="A personal blog for Markdown-based technical articles."
>
	<main class="page-shell">
		<section class="grid gap-4 py-[clamp(1.5rem,8vw,5rem)] pb-[clamp(1.6rem,5vw,3.4rem)]" aria-labelledby="page-title">
			<h1 id="page-title" class="hero-title">Petar I</h1>
			<p class="hero-copy">
				These are my personal technical notes: some are distilled from long AI-assisted conversations and shaped into articles, while others are written entirely by me.
			</p>
			<p class="hero-copy-small">
				If you don't like the UI (it was vibe-coded with Codex; blame him, it's readable enough for me), you can find the articles in the <a href="https://github.com/PetarIvanov01/tech-blogy" rel="noopener noreferrer" target="_blank">[repo]</a>.
			</p>
		</section>

		<section id="articles" aria-label="Articles">
			<div class="mb-4 flex flex-wrap gap-2" aria-label="Content filters">
				<button
					class="content-filter rounded-full border border-ink bg-ink px-3 py-2 font-mono text-[0.74rem] leading-none text-panel uppercase sm:py-1.5 sm:text-xs"
					type="button"
					data-filter="all"
					aria-pressed="true"
				>
					All
				</button>
				<button
					class="content-filter rounded-full border border-line px-3 py-2 font-mono text-[0.74rem] leading-none text-muted uppercase hover:text-ink focus-visible:text-ink sm:py-1.5 sm:text-xs"
					type="button"
					data-filter="article"
					aria-pressed="false"
				>
					Articles
				</button>
				<button
					class="content-filter rounded-full border border-line px-3 py-2 font-mono text-[0.74rem] leading-none text-muted uppercase hover:text-ink focus-visible:text-ink sm:py-1.5 sm:text-xs"
					type="button"
					data-filter="folder"
					aria-pressed="false"
				>
					Folders
				</button>
			</div>

			{homepageItems.map((item) => {
				if (item.type === 'series') {
					return (
						<BlogPostCard
							href={getSeriesHref(item.series)}
							title={item.series.title}
							description={item.series.description}
							displayDate={item.series.displayDate}
							label="Folder"
							variant="series"
							tags={item.series.tags}
						/>
					);
				}

				return (
					<BlogPostCard
						href={`/blog/${item.post.id}/`}
						title={item.post.data.title}
						description={item.post.data.description}
						pubDate={item.post.data.pubDate}
						tags={item.post.data.tags}
					/>
				);
			})}
		</section>
	</main>

	<script>
		const filterButtons = document.querySelectorAll<HTMLButtonElement>('.content-filter');
		const cards = document.querySelectorAll<HTMLElement>('[data-card-type]');

		for (const button of filterButtons) {
			button.addEventListener('click', () => {
				const filter = button.dataset.filter ?? 'all';

				for (const card of cards) {
					card.hidden = filter !== 'all' && card.dataset.cardType !== filter;
				}

				for (const filterButton of filterButtons) {
					const isActive = filterButton === button;
					filterButton.setAttribute('aria-pressed', String(isActive));
					filterButton.classList.toggle('bg-ink', isActive);
					filterButton.classList.toggle('border-ink', isActive);
					filterButton.classList.toggle('text-panel', isActive);
					filterButton.classList.toggle('border-line', !isActive);
					filterButton.classList.toggle('text-muted', !isActive);
					filterButton.classList.toggle('hover:text-ink', !isActive);
					filterButton.classList.toggle('focus-visible:text-ink', !isActive);
				}
			});
		}
	</script>
</Layout>
