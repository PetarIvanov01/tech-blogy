---
import { getCollection } from 'astro:content';
import BlogPostCard from '../../components/BlogPostCard.astro';
import Layout from '../../layouts/Layout.astro';
import { seriesMetadata, sortPostsBySeriesOrder } from '../../lib/series';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

	return seriesMetadata
		.map((series) => {
			const seriesPosts = sortPostsBySeriesOrder(
				posts.filter((post) => post.data.series === series.key),
			);

			return {
				series,
				posts: seriesPosts,
			};
		})
		.filter(({ posts }) => posts.length > 0)
		.map(({ series, posts }) => ({
			params: { series: series.slug },
			props: { series, posts },
		}));
}

const { series, posts } = Astro.props;
const chapterCount = posts.length;
---

<Layout title={`${series.title} | Petar I`} description={series.description}>
	<main class="page-shell">
		<section class="grid gap-4 py-[clamp(1.5rem,8vw,5rem)] pb-[clamp(1.6rem,5vw,3.4rem)]" aria-labelledby="page-title">
			<p class="eyebrow">Series</p>
			<h1 id="page-title" class="hero-title">{series.title}</h1>
			<p class="hero-copy">{series.description}</p>
			<p class="m-0 font-mono text-[0.78rem] leading-[1.5] text-muted uppercase sm:text-[0.82rem]">
				{series.displayDate && <>{series.displayDate} · </>}
				{chapterCount} {chapterCount === 1 ? 'chapter' : 'chapters'}
			</p>
		</section>

		<section id="chapters" aria-label={`${series.title} chapters`}>
			{posts.map((post) => (
				<BlogPostCard
					href={`/blog/${post.id}/`}
					title={post.data.title}
					description={post.data.description}
					tags={post.data.tags}
				/>
			))}
		</section>
	</main>
</Layout>
