---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Petar I',
	description = 'Personal notes and technical articles.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="page-shell py-5 pb-4 sm:py-8 sm:pb-5">
			<nav
				class="flex flex-col items-start justify-between gap-3 border-b border-line pb-4 text-[0.95rem] sm:flex-row sm:items-center sm:gap-4 sm:text-base"
				aria-label="Main navigation"
			>
				<a class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline" href="/">Home</a>
				<div class="flex flex-wrap gap-x-4 gap-y-2 text-[0.92rem] text-muted sm:text-[0.95rem]">
					<a
						class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline"
						href="https://github.com/PetarIvanov01"
						rel="me noreferrer"
						target="_blank"
					>
						GitHub
					</a>
					<a
						class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline"
						href="https://www.linkedin.com/in/petar-ivanov-7a986b248/"
						rel="me noreferrer"
						target="_blank"
					>
						LinkedIn
					</a>
				</div>
			</nav>
		</header>
		<slot />
		<button type="button" class="scroll-top-button" data-scroll-top aria-label="Scroll to top">
			<span class="scroll-top-icon" aria-hidden="true"></span>
		</button>
		<script>
			const scrollTopButton = document.querySelector<HTMLButtonElement>('[data-scroll-top]');

			if (scrollTopButton) {
				const updateScrollTopButton = () => {
					const visibleAfter = window.matchMedia('(max-width: 639px)').matches ? 240 : 420;
					scrollTopButton.classList.toggle('is-visible', window.scrollY > visibleAfter);
				};

				scrollTopButton.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});

				window.addEventListener('scroll', updateScrollTopButton, { passive: true });
				window.addEventListener('resize', updateScrollTopButton);
				updateScrollTopButton();
			}
		</script>
	</body>
</html>
