---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Petar I',
	description = 'Personal notes and technical articles.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="page-shell py-8 pb-5">
			<nav
				class="flex flex-col items-start justify-between gap-4 border-b border-line pb-4 sm:flex-row sm:items-center"
				aria-label="Main navigation"
			>
				<a class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline" href="/">Home</a>
				<div class="flex gap-4 text-[0.95rem] text-muted">
					<a
						class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline"
						href="https://github.com/PetarIvanov01"
						rel="me noreferrer"
						target="_blank"
					>
						GitHub
					</a>
					<a
						class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline"
						href="https://www.linkedin.com/in/petar-ivanov-7a986b248/"
						rel="me noreferrer"
						target="_blank"
					>
						LinkedIn
					</a>
				</div>
			</nav>
		</header>
		<slot />
	</body>
</html>
