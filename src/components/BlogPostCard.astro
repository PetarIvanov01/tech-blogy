---
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate?: Date;
  displayDate?: string;
  label?: string;
  variant?: 'post' | 'series';
  tags?: string[];
}

const { href, title, description, pubDate, displayDate, label, variant = 'post', tags = [] } = Astro.props;
const isSeries = variant === 'series';
const formattedDate = pubDate
  ? new Intl.DateTimeFormat('en', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    }).format(pubDate)
  : displayDate;
---

<article
  class={isSeries ? 'border-t border-line py-3 first:border-t-0' : 'border-t border-line'}
  data-card-type={isSeries ? 'folder' : 'article'}
>
  <a
    href={href}
    class:list={[
      'group grid min-w-0 gap-3 text-inherit no-underline',
      isSeries
        ? 'rounded-xl border border-line-strong bg-paper px-4 py-5 shadow-sm transition-colors hover:bg-panel-muted focus-visible:bg-panel-muted sm:px-5'
        : 'py-5 sm:py-6',
    ]}
  >
    {(label || formattedDate) && (
      <div class="flex flex-wrap items-center gap-2 font-mono text-[0.74rem] leading-[1.45] text-muted uppercase sm:text-xs">
        {label && <span class={isSeries ? 'rounded-full border border-line bg-panel px-2 py-1' : ''}>{label}</span>}
        {
          pubDate && formattedDate ? (
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          ) : (
            formattedDate && <span>{formattedDate}</span>
          )
        }
      </div>
    )}
    <h2 class="m-0 text-[clamp(1.2rem,6vw,2rem)] leading-[1.18] text-ink group-hover:underline group-focus-visible:underline underline-offset-[0.18em] break-words">{title}</h2>
    <p class="m-0 w-full max-w-[76ch] text-[0.98rem] leading-[1.65] text-muted sm:text-base">{description}</p>
    {
      tags.length > 0 && (
        <ul class="m-0 flex list-none flex-wrap gap-2 p-0" aria-label="Tags">
          {tags.map((tag) => (
            <li class="rounded-full border border-line px-2 py-1 font-mono text-[0.74rem] leading-[1.35] text-muted sm:text-xs">{tag}</li>
          ))}
        </ul>
      )
    }
  </a>
</article>
