---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const tocId = `toc-items-${Astro.url.pathname.replaceAll('/', '-').replace(/^-+|-+$/g, '') || 'post'}`;
---

{
	headings.length > 0 && (
		<aside class="toc-shell" aria-label="Table of contents">
			<nav class="toc-nav">
				<div class="toc-header">
					<p class="toc-title">On this page</p>
					<button
						type="button"
						class="toc-toggle"
						aria-expanded="true"
						aria-controls={tocId}
						data-toc-toggle
					>
						Toggle
					</button>
				</div>
				<div id={tocId} class="toc-body" data-toc-body>
					<ul class="toc-list">
						{headings.map((heading) => (
							<li>
								<a
									href={`#${heading.slug}`}
									class="toc-link"
									data-toc-link={heading.slug}
									style={`padding-left: ${heading.depth === 3 ? '0.9rem' : '0'};`}
								>
									{heading.text}
								</a>
							</li>
						))}
					</ul>
				</div>
			</nav>
		</aside>
	)
}

<script>
	const toggle = document.querySelector('[data-toc-toggle]');
	const body = document.querySelector('[data-toc-body]');
	const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
	const headings = tocLinks
		.map((link) => {
			const slug = link.dataset.tocLink;
			const heading = slug ? document.getElementById(slug) : null;

			return heading ? { slug, heading, link } : null;
		})
		.filter((item): item is { slug: string; heading: HTMLElement; link: HTMLAnchorElement } =>
			Boolean(item),
		);

	if (toggle instanceof HTMLButtonElement && body instanceof HTMLElement) {
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			body.hidden = expanded;
		});
	}

	if (headings.length > 0) {
		let activeSlug = '';
		let frameRequest = 0;
		const topOffset = 140;

		const clearActiveHeading = () => {
			if (!activeSlug) {
				return;
			}

			activeSlug = '';

			for (const { link } of headings) {
				link.classList.remove('is-active');
				link.removeAttribute('aria-current');
			}

			const nextUrl = `${window.location.pathname}${window.location.search}`;
			window.history.replaceState(null, '', nextUrl);
		};

		const setActiveHeading = (slug: string) => {
			if (slug === activeSlug) {
				return;
			}

			activeSlug = slug;

			for (const { slug: itemSlug, link } of headings) {
				const isActive = itemSlug === slug;
				link.classList.toggle('is-active', isActive);

				if (isActive) {
					link.setAttribute('aria-current', 'true');
					link.scrollIntoView({ block: 'nearest' });
				} else {
					link.removeAttribute('aria-current');
				}
			}

			const nextUrl = `${window.location.pathname}${window.location.search}#${slug}`;
			window.history.replaceState(null, '', nextUrl);
		};

		const updateActiveHeading = () => {
			frameRequest = 0;
			let current: (typeof headings)[number] | null = null;

			for (const item of headings) {
				if (item.heading.getBoundingClientRect().top <= topOffset) {
					current = item;
				} else {
					break;
				}
			}

			if (current) {
				setActiveHeading(current.slug);
			} else {
				clearActiveHeading();
			}
		};

		const scheduleUpdate = () => {
			if (frameRequest === 0) {
				frameRequest = window.requestAnimationFrame(updateActiveHeading);
			}
		};

		window.addEventListener('scroll', scheduleUpdate, { passive: true });
		window.addEventListener('resize', scheduleUpdate);
		updateActiveHeading();
	}
</script>
