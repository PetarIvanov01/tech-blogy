---
const year = new Date().getFullYear();
---

<footer class="page-shell py-8 pt-6 sm:py-10 sm:pt-8">
	<div
		class="flex flex-col gap-4 border-t border-line pt-6 sm:flex-row sm:items-center sm:justify-between sm:pt-8"
	>
		<p class="m-0 text-[0.82rem] leading-normal text-muted sm:text-[0.88rem]">
			© {year} Petar I
		</p>
		<nav
			class="flex flex-wrap gap-x-4 gap-y-2 text-[0.82rem] leading-normal text-muted sm:text-[0.88rem]"
			aria-label="Footer"
		>
			<a
				class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline"
				href="https://github.com/PetarIvanov01"
				rel="me noreferrer"
				target="_blank"
			>
				GitHub
			</a>
			<a
				class="no-underline underline-offset-[0.18em] hover:text-ink hover:underline focus-visible:text-ink focus-visible:underline"
				href="https://www.linkedin.com/in/petar-ivanov-7a986b248/"
				rel="me noreferrer"
				target="_blank"
			>
				LinkedIn
			</a>
